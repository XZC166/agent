FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     blastFoam;

startFrom       startTime;

startTime       0;
stopAt          endTime;
endTime         0.01;  // Simulate for 10 ms

deltaT          1e-7;  // Initial time step [s]
maxDeltaT       1e-5;  // Maximum time step limited by physics

writeControl    adjustableRunTime;
writeInterval   0.0005;  // Output every 0.5 ms

purgeWrite      0;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;
adjustTimeStep  yes;
maxCo           0.5;    // Maximum Courant number
maxCcourant     0.5;    // Maximum convective Courant number

functions
{
    // Optional: Add probes, force calculations, etc.
}

