FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0.01";
    object      rhoE;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 245000;

boundaryField
{
    inlet
    {
        type            calculated;
        value           uniform 245000;
    }
    outlet
    {
        type            calculated;
        value           uniform 245000;
    }
    front
    {
        type            calculated;
        value           uniform 245000;
    }
    back
    {
        type            calculated;
        value           uniform 245000;
    }
    bottom
    {
        type            calculated;
        value           uniform 245000;
    }
    top
    {
        type            calculated;
        value           uniform 245000;
    }
}


