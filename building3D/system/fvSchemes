FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

fluxScheme Kurganov;

ddtSchemes
{
    default         Euler;
    timeIntegrator  Euler;
}

gradSchemes
{
    default         Gauss linear;
}

divSchemes
{
    default         none;
    div(phi,U)      Gauss upwind;
    div(phi,e)      Gauss upwind;
    div(phi,p)      Gauss upwind;
    div(phi,rho)    Gauss upwind;
    div(phi,alpha)  Gauss upwind;
}

laplacianSchemes
{
    default         none;
    laplacian(mu,U) Gauss linear corrected;
    laplacian(alpha,e) Gauss linear corrected;
    laplacian(alpha,p) Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
    reconstruct(rho) vanLeer;
    reconstruct(U)   vanLeerV;
    reconstruct(p)   vanLeer;
    reconstruct(e)   vanLeer;
    reconstruct(speedOfSound)  vanLeer;
    reconstruct(alpha) vanLeer;
}

snGradSchemes
{
    default         corrected;
}

fluxRequired
{
    default         no;
    p               ;
    U               ;
    e               ;
    rho             ;
    alpha           ;
}

