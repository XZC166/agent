FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

regions
(
    // Cylindrical explosive charge (25kg C4) near origin
    // Cylinder: radius=0.1m, height=0.2m, center at (1 1 0.1)
    cylinderToCell
    {
        p1          (1 1 0);
        p2          (1 1 0.2);
        radius      0.1;
        fieldValues
        (
            volScalarFieldValue alpha.C4 1
            volScalarFieldValue alpha.Air 0
            volScalarFieldValue e 2000000
        );
    }
);

