FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh true;
snap            true;
addLayers       false;

geometry
{
    L_Wall.stl
    {
        type triSurfaceMesh;
        name L_Wall;
    }
}

castellatedMeshControls
{
    maxLocalCells 1000000;
    maxGlobalCells 2000000;
    minRefinementCells 10;
    nCellsBetweenLevels 2;

    features
    (
        {
            file "L_Wall.eMesh";
            level 2;
        }
    );

    refinementSurfaces
    {
        L_Wall { level (2 3); }
    }

    resolveFeatureAngle 30;

    refinementRegions
    {
        L_Wall { mode inside; levels ((1E-3 3)); }
    }

    locationInMesh (5 5 2.5);
    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch 3;
    tolerance 4.0;
    nSolveIter 300;
    nRelaxIter 5;
}

meshQualityControls
{
    maxNonOrtho 65;
    maxBoundarySkewness 20;
    maxInternalSkewness 4;
    minVol 1e-13;
    minTetQuality 1e-30;
    minArea -1;
    minTwist 0.02;
    minDeterminant 0.001;
}

debug 0;
mergeTolerance 1E-6;