FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultFieldValues
(
    volScalarFieldValue alpha.C4 0
    volScalarFieldValue alpha.Air 1
    volScalarFieldValue e 250000
);

regions
(
    sphereToCell
    {
        centre (0 0 0);
        radius 0.5;
        fieldValues
        (
            volScalarFieldValue alpha.C4 1
            volScalarFieldValue alpha.Air 0
            volScalarFieldValue e 4200000
        );
    }
);