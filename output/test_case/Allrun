#!/bin/bash

# ==========================================================
# Allrun script for blastFoam 3D Building Blast Case
# Domain: 10m x 10m x 10m
# Based on building3D tutorial & blastFoam conventions
# ==========================================================

# Exit on any error
set -e

# Source OpenFOAM environment (assumes standard installation)
if [ -f "$FOAM_ENV" ]; then
    source $FOAM_ENV
elif [ -f "$WM_PROJECT_DIR/etc/bashrc" ]; then
    source $WM_PROJECT_DIR/etc/bashrc
else
    echo "Error: OpenFOAM environment not found. Please source OpenFOAM first."
    exit 1
fi

# --- Step 1: Generate background mesh with blockMesh ---
echo "Running blockMesh..."
blockMesh

# --- Step 2: Extract surface features from STL ---
echo "Running surfaceFeatureExtract..."
surfaceFeatureExtract -includedAngle 150 -writeObj -scale 1.0 constant/triSurface/L_Wall.stl

# --- Step 3: Generate refined mesh with snappyHexMesh ---
echo "Running snappyHexMesh..."
snappyHexMesh -overwrite

# --- Step 4: Set initial fields (e.g., charge initialization) ---
echo "Running setFields..."
setFields

# --- Step 5: Run blastFoam solver ---
echo "Running blastFoam..."
blastFoam

# --- Optional: Convert results to VTK for ParaView ---
# echo "Running foamToVTK..."
# foamToVTK -latestTime

echo "Allrun completed successfully."
